# ============================================================
# eSakha 2.0 — Environment Variables
# Copy this file to .env.local (for local dev) and fill in real
# values. In production (Vercel), add these in your Project
# Settings → Environment Variables instead of committing a file.
# ============================================================

# --- Supabase ---------------------------------------------------
# Found in your Supabase project: Settings → API
# Existing project reference seen in the old codebase: tncmdaxkmkbsophkxvsp
# (confirm this is still the right project before reusing it)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed later for the admin panel (server-side only — never
# expose this with a NEXT_PUBLIC_ prefix, never commit it).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Razorpay -----------------------------------------------------
# The key ID is safe to expose publicly (it's how Razorpay's widget
# identifies your account). Falls back to the key already used in
# the original site if this is left unset.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# Only needed later for server-side payment verification / webhooks.
# Never expose this publicly.
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# --- OpenAI (for the AI Assistant) -----------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — defaults to gpt-4o-mini if unset. Any OpenAI chat model that
# supports tool calling works (e.g. gpt-4o, gpt-4o-mini, gpt-4.1-mini).
OPENAI_MODEL=gpt-4o-mini
